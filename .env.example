# Copy to .env and fill in values

# Relay
PORT=7402
RELAY_USDC_RECIPIENT=S4H6n6EKqZZzdfsCGkXGFkVw6Mu7NV8cgdtTB2NFHZ9

# Agent
RELAY_URL=http://localhost:7402

# Bhairab — powers both THINK (reasoning) and SCAN (risk) on Bittensor SN64.
# Get a key at tao-gateway.vercel.app; the gateway routes "auto" to a Chutes SN64 model.

BHAIRAB_API_KEY=
# Optional overrides:
# BHAIRAB_THINK_MODEL=auto
# DEMO_HONEYPOT=1   # point the SCAN at a live freeze-authority honeypot

# RPC (use Helius for demo runs; devnet public as fallback)
SOLANA_RPC_URL=https://api.devnet.solana.com

